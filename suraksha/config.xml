<?xml version='1.0' encoding='utf-8'?>
<widget id="com.yourorg.surakshayatri"
        version="1.0.0"
        xmlns="http://www.w3.org/ns/widgets"
        xmlns:cdv="http://cordova.apache.org/ns/1.0">

    <!-- App Info -->
    <name>SurakshaYatri</name>
    <description>Tourism & Safety Dashboard App</description>
    <author email="you@example.com" href="https://yourdomain.com">
        SurakshaYatri Team
    </author>

    <!-- Entry point -->
    <content src="index.html" />

    <!-- Allow network requests -->
    <access origin="*" />
    <allow-navigation href="*" />

    <!-- Allow external intents (links, dial, maps etc.) -->
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <!-- Platform-specific preferences -->
    <platform name="ios">
        <preference name="CordovaWebViewEngine" value="CDVWKWebViewEngine" />
        <preference name="AllowInlineMediaPlayback" value="true" />
        <edit-config target="NSCameraUsageDescription" file="*-Info.plist" mode="merge">
            <string>This app requires camera access to take photos for reporting and verification.</string>
        </edit-config>
        <edit-config target="NSLocationWhenInUseUsageDescription" file="*-Info.plist" mode="merge">
            <string>This app requires your location to show nearby police stations and points of interest.</string>
        </edit-config>
    </platform>

    <platform name="android">
        <preference name="android-minSdkVersion" value="21" />
        <preference name="android-targetSdkVersion" value="34" />
        <edit-config file="AndroidManifest.xml" mode="merge" target="/manifest/uses-permission">
            <uses-permission android:name="android.permission.CAMERA" />
            <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
            <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
            <uses-permission android:name="android.permission.INTERNET" />
        </edit-config>
    </platform>

    <!-- Plugin settings -->
    <plugin name="cordova-plugin-whitelist" spec="^1.3.5" />
    <plugin name="cordova-plugin-geolocation" spec="^4.1.0" />
    <plugin name="cordova-plugin-camera" spec="^6.0.0" />
    <plugin name="cordova-plugin-network-information" spec="^3.0.0" />

</widget>
